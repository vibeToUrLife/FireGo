# Copy this file to .env and fill in real values:
#
#   cp .env.example .env
#
# Both the Next.js app and the Prisma CLI read .env, so keep everything here.
# Nothing in this example is secret — these are placeholders.

# --- Database (Postgres) ---
# Any Postgres works (Supabase, Neon, Vercel Postgres, local…).
#
# DATABASE_URL  = the connection your APP uses. For serverless/Vercel, use a
#                 POOLED string (Supabase: the transaction pooler, port 6543).
# DIRECT_URL    = a DIRECT/session connection used only for migrations
#                 (Supabase: the session pooler, port 5432). Optional but
#                 recommended; if omitted, migrations fall back to DATABASE_URL.
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://user:password@host:5432/postgres"

# --- Auth.js ---
# Required. Generate one with:  npx auth secret
AUTH_SECRET="generate-a-long-random-string"

# --- Google OAuth (optional) ---
# Leave both blank to hide the "Sign in with Google" button.
# Redirect URI (local):     http://localhost:3000/api/auth/callback/google
# Redirect URI (production): https://your-domain.com/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
