// Prisma schema — the shape of our Postgres database.
//
// Prisma 7 note: the connection URL lives in `prisma.config.ts` (loaded from
// .env), not here, and the generated client is emitted into
// `src/generated/prisma` (git-ignored, rebuilt by `prisma generate`).
//
// Models below are split in two groups:
//   1. Auth.js tables (User / Account / Session / VerificationToken) — the
//      standard set the Prisma adapter expects, plus our own `passwordHash`
//      field so the email/password flow can store a hashed password.
//   2. Our domain table: Plan — a named retirement scenario owned by a user.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  // Set for email/password users; null for people who only sign in with Google.
  passwordHash  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  plans    Plan[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// A saved retirement scenario. The calculator inputs are stored as a single
// JSON blob validated by our Zod schema on the way in — that keeps the database
// schema stable as the input set evolves, with Zod as the single source of truth.
model Plan {
  id        String   @id @default(cuid())
  userId    String
  name      String
  inputs    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
